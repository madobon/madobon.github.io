{
  "name": "madobon.github.io",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "dev:all": "concurrently -k -n site,slides -c blue,magenta \"vp dev\" \"pnpm --dir talks/welcome exec slidev slides.md --port 3030 --base /talks/welcome/\"",
    "build": "pnpm run build:site && pnpm run build:talks",
    "build:site": "tsc && vite-ssg build",
    "build:talks": "node scripts/build-talks.mjs",
    "preview": "vp preview",
    "prepare": "vp config"
  },
  "dependencies": {
    "@unhead/vue": "2.1.12",
    "@vitejs/plugin-vue": "6.0.5",
    "vite-ssg": "28.3.0",
    "vue": "3.5.32",
    "vue-router": "5.0.4"
  },
  "devDependencies": {
    "concurrently": "9.2.1",
    "typescript": "5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.15",
    "vite-plus": "0.1.15"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.15",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.15"
  },
  "engines": {
    "pnpm": "10.27.0"
  },
  "packageManager": "pnpm@10.27.0"
}
