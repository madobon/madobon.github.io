{
  "name": "madobon.github.io",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "npm run build:site && npm run build:talks",
    "build:site": "tsc && vite-ssg build",
    "build:talks": "npm run build:talk:welcome",
    "build:talk:welcome": "npm --prefix talks/welcome run build -- --out ../../dist/talks/welcome",
    "preview": "vp preview",
    "prepare": "vp config"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "vite-ssg": "^28.3.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "npm@11.12.1"
}
